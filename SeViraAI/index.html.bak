    <!-- BotÃ£o Voltar ao Topo -->
    <button id="backToTopBtn" class="fixed bottom-8 right-8 bg-construction text-asphalt w-12 h-12 rounded-full flex items-center justify-center text-xl shadow-[0_0_15px_rgba(255,215,0,0.4)] hover:bg-construction-hover hover:scale-110 transition-all duration-300 z-50 opacity-0 invisible translate-y-4" aria-label="Voltar ao topo">
        <i class="fa-solid fa-arrow-up"></i>
    </button>

    <!-- Script do Contador -->
    <script>
            // 1. LÃ³gica do Contador
            const countDownDate = new Date().getTime() + (48 * 60 * 60 * 1000);
            const countdownEl = document.getElementById("countdown");

            const x = setInterval(function() {
                const now = new Date().getTime();
                const distance = countDownDate - now;

                const hours = Math.floor((distance % (1000 * 60 * 60 * 24 * 10)) / (1000 * 60 * 60));
                const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                countdownEl.innerHTML = 
                    hours.toString().padStart(2, '0') + "h: " + 
                    minutes.toString().padStart(2, '0') + "m: " + 
                    seconds.toString().padStart(2, '0') + "s";

                // Visual Indicator: Color change and animation when < 1 hour
                if (distance < 3600000) {
                    countdownEl.classList.add('text-red-500', 'animate-pulse');
                }

                if (distance < 0) {
                    clearInterval(x);
                    countdownEl.innerHTML = "ENCERRADO";
                    countdownEl.classList.remove('text-red-500', 'animate-pulse');
                }
            }, 1000);

            // Toggle ARIA expanded for FAQ
            document.querySelectorAll('details').forEach(detail => {
                detail.addEventListener('toggle', () => {
                    detail.setAttribute('aria-expanded', detail.open);
                });
            });

            // Global Scroll Listener (Optimized with requestAnimationFrame)
        const parallaxBg = document.getElementById('parallax-bg');
        const backToTopBtn = document.getElementById('backToTopBtn');
        const scrollProgressBar = document.getElementById('scrollProgressBar');
        let isScrolling = false;

        window.addEventListener('scroll', () => {
            if (!isScrolling) {
                window.requestAnimationFrame(() => {
                    const scrolled = window.scrollY;
                    const windowHeight = window.innerHeight;

                    // 1. Parallax Background
                    if (parallaxBg) {
                        parallaxBg.style.transform = `translateY(${scrolled * 0.3}px)`;
                    }

                    // 3. LÃ³gica do BotÃ£o Voltar ao Topo
                    if (backToTopBtn) {
                        if (scrolled > 300) {
                            backToTopBtn.classList.remove('opacity-0', 'invisible', 'translate-y-4');
                            backToTopBtn.classList.add('opacity-100', 'visible', 'translate-y-0');
                        } else {
                            backToTopBtn.classList.add('opacity-0', 'invisible', 'translate-y-4');
                            backToTopBtn.classList.remove('opacity-100', 'visible', 'translate-y-0');
                        }
                    }

                    // 4. LÃ³gica da Barra de Progresso
                    if (scrollProgressBar) {
                        const scrollTop = scrolled || document.documentElement.scrollTop;
                        const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
                        const scrollPercentage = (scrollTop / scrollHeight) * 100;
                        scrollProgressBar.style.width = scrollPercentage + '%';
                    }

                    isScrolling = false;
                });
                isScrolling = true;
            }
        });

        backToTopBtn.addEventListener('click', () => {
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        });

        // 5. LÃ³gica da Galeria (Grid + Filtro + Load More)
        const portfolioGrid = document.getElementById('portfolio-grid');
        const filterBtns = document.querySelectorAll('.filter-btn');
        const loadMoreBtn = document.getElementById('loadMoreBtn');
        const itemsPerPage = 8;
        let currentPage = 1;
        let currentFilter = 'all';

        function updateGallery() {
            const items = document.querySelectorAll('.portfolio-item');
            let visibleCount = 0;
            let totalMatch = 0;

            items.forEach(item => {
                const category = item.getAttribute('data-category');
                const matchesFilter = currentFilter === 'all' || category === currentFilter;
                
                if (matchesFilter) {
                    totalMatch++;
                    if (visibleCount < currentPage * itemsPerPage) {
                        item.classList.remove('hidden');
                        // Trigger a small entrance animation
                        setTimeout(() => item.style.opacity = '1', 10);
                        visibleCount++;
                    } else {
                        item.classList.add('hidden');
                        item.style.opacity = '0';
                    }
                } else {
                    item.classList.add('hidden');
                    item.style.opacity = '0';
                }
            });

            // Show/Hide Load More button
            if (loadMoreBtn) {
                if (visibleCount < totalMatch) {
                    loadMoreBtn.parentElement.classList.remove('hidden');
                } else {
                    loadMoreBtn.parentElement.classList.add('hidden');
                }
            }
        }

        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const filter = btn.getAttribute('data-filter');
                currentFilter = filter;
                currentPage = 1; // Reset to first page on filter change
                
                // Update active button UI
                filterBtns.forEach(b => {
                    b.classList.remove('active', 'border-construction/30', 'text-construction');
                    b.classList.add('border-white/10', 'text-gray-400');
                });
                btn.classList.add('active', 'border-construction/30', 'text-construction');
                btn.classList.remove('border-white/10', 'text-gray-400');

                updateGallery();
            });
        });

        if (loadMoreBtn) {
            loadMoreBtn.addEventListener('click', () => {
                currentPage++;
                updateGallery();
            });
        }

        // Initial setup
        document.addEventListener('DOMContentLoaded', () => {
            // Initialize opacity for transition
            document.querySelectorAll('.portfolio-item').forEach(item => {
                item.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
                item.style.opacity = '0';
            });
            updateGallery();
        });
    </script>
</body>
</html>
