            <!-- Swiper JS -->
            <!-- <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script> -->
            <script>
                function createSwiperSlide(i) {
                    return `
                        <div class="swiper-slide !w-auto">
                            <div class="w-[260px] md:w-[300px] aspect-[3/4] bg-concrete rounded-xl overflow-hidden border border-construction/30 relative group hover:shadow-[0_0_20px_rgba(255,215,0,0.3)] transition-all animate-pulse-glow flex items-center justify-center">
                                <img src="/assets/capas/capa-${i}.png" alt="Capa Curso ${i}" class="w-full h-full object-contain opacity-90 group-hover:opacity-100 transition-transform duration-500 group-hover:scale-105" referrerPolicy="no-referrer" loading="lazy" onerror="this.src='https://placehold.co/1080x1440/333/FFD700?text=MÃ³dulo+${i}'">
                            </div>
                        </div>
                    `;
                }

                const wrapper1 = document.getElementById('swiper-wrapper-1');
                const wrapper2 = document.getElementById('swiper-wrapper-2');
                
                let html1 = '';
                for(let i=1; i<=13; i++) html1 += createSwiperSlide(i);
                if(wrapper1) wrapper1.innerHTML = html1;

                let html2 = '';
                for(let i=14; i<=26; i++) html2 += createSwiperSlide(i);
                if(wrapper2) wrapper2.innerHTML = html2;

                // Initialize Swipers
                const swiperConfig = {
                    spaceBetween: 32,
                    slidesPerView: 'auto',
                    loop: true,
                    freeMode: true,
                    speed: 5000,
                    allowTouchMove: true,
                    grabCursor: true,
                    autoplay: {
                        delay: 0,
                        disableOnInteraction: false,
                    },
                    a11y: true,
                };

                new Swiper('.swiper-row-1', {
                    ...swiperConfig,
                });

                new Swiper('.swiper-row-2', {
                    ...swiperConfig,
                    autoplay: {
                        delay: 0,
                        disableOnInteraction: false,
                        reverseDirection: true,
                    }
                });
            </script>
